// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  user_id String @id @default(uuid()) @db.VarChar(36)
  customer_number String @unique @db.VarChar(10)
  username String
  email    String?
  phoneNumber String  
  password String
  role     String
  profile String?
  point Int @default(0)
  province String? 
  district String? 
  village  String? 
  coperate       String?
  corperate_name String? 
  gender String? 
  first_name String?
  last_name  String?
  dob DateTime? @db.DateTime
  ocupation String? 
  nationality String? 
  house String? 
  unit  String? 
  street String? 
  pobox String? 
  address String?
  deviceToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  GiftHistory GiftHistory[]
  Card        Card[]
  Car         Car[]
  booking     Booking[]
  Employee    Employee[]
}

model Employee {
  employee_id   String   @id @default(uuid()) @db.VarChar(36)
  employee_code String
  employee_name String
  position      String
  branchId      String   @db.VarChar(36)
  branch        Branch   @relation(fields: [branchId], references: [branch_id])
  userId        String   @db.VarChar(36)
  user          User     @relation(fields: [userId], references: [user_id])
  createBy      String?  @db.VarChar(36)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Branch {
  branch_id   String     @id @default(uuid()) @db.VarChar(36)
  branch_code String
  branch_name String
  location    String
  phone       String?
  createBy    String?    @db.VarChar(36)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  Employee    Employee[]
  bookings    Booking[]
  timeFixes   TimeFix[]
}

model Promotion {
  promotion_id String   @id @default(uuid()) @db.VarChar(36)
  title        String
  detail       String   @db.Text
  image        String
  createBy     String?  @db.VarChar(36)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Service {
  service_id     String          @id @default(uuid()) @db.VarChar(36)
  serviceName    String
  description    String
  image          String
  createBy       String?       
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bookingDetails BookingDetail[]
}

model GiftCard {
  giftcard_id  String         @id @default(uuid()) @db.VarChar(36)
  gift_Code    String         @unique 
  gift_Name    String?        
  gift_Point   Float?
  amount       Int
  image        String
  status       Boolean        @default(true)
  createBy     String?       
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  GiftHistory  GiftHistory[]
}

model GiftHistory {
  gifthistory_id String   @id @default(uuid()) @db.VarChar(36)
  userId         String  
  user           User     @relation(fields: [userId], references: [user_id])
  giftcardId     String   
  giftcard       GiftCard @relation(fields: [giftcardId], references: [giftcard_id])
  cardId         String  
  card           Card    @relation(fields: [cardId], references: [card_id])
  card_number    String  
  gift_Code      String  
  claimed_date   DateTime @db.DateTime
  amount         Int
  total          Int?
  status         Boolean  @default(true)
  createBy       String?  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Card {
  card_id         String         @id @default(uuid()) @db.VarChar(36)
  userId          String         
  user            User           @relation(fields: [userId], references: [user_id])
  customer_number String         
  card_number     String         @unique 
  vip_number      String         
  card_type       String?        
  goldIssued      DateTime?      @db.DateTime
  received        String?        
  issued_date     DateTime?      @db.DateTime
  expiration_date DateTime?      @db.DateTime

  plate_number    String?        
  vehicle_model   String?        
  color           String?        
  frame_number    String?        
  engine_number   String?        

  active_point    Float?
  total_point     Float?

  running_part    Float?
  running_labour  Float?
  countCard       Decimal?       
  createBy        String?        
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  GiftHistory     GiftHistory[]
  Fix          Fix[]
}




model Car {
  car_id       String    @id @default(uuid()) @db.VarChar(36)
  userId       String?   
  user         User?     @relation(fields: [userId], references: [user_id])
  model        String
  frameNumber  String
  engineNumber String
  plateNumber  String
  province     String
  color        String?
  createBy     String?   
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  booking      Booking[]
  

}

model Setting {
  setting_id String   @id @default(uuid()) @db.VarChar(36)
  priceFix   Int // 1,000,000 / 100,000 = 10
  pricePart  Int // 500,000 / 50,000 = 10 20
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TimeFix {
  timefix_id String   @id @default(uuid()) @db.VarChar(36)
  timeId     String   @db.VarChar(36)
  time       Time     @relation(fields: [timeId], references: [time_id])
  branch     Branch?  @relation(fields: [branchId], references: [branch_id])
  branchId   String?  @db.VarChar(36)
  zoneId     String   @db.VarChar(36)
  zone       Zone     @relation(fields: [zoneId], references: [zone_id])
  date       DateTime @db.DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Time {
  time_id    String    @id @default(uuid()) @db.VarChar(36)
  time       String
  date       String?
  timeStatus Boolean   @default(true)
  qty        Int       @default(0)
  createBy   String?   
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  timeFixes  TimeFix[]
  bookings   Booking[]
}

model Zone {
  zone_id    String    @id @default(uuid()) @db.VarChar(36)
  zoneName   String
  timeFix    String?
  zoneStatus Boolean
  createBy   String?   
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  timeFixes  TimeFix[]
  bookings   Booking[]
}

model Booking {
  booking_id     String          @id @default(uuid()) @db.VarChar(36)
  userId         String          @db.VarChar(36)
  user           User            @relation(fields: [userId], references: [user_id])
  carId          String          @db.VarChar(36)
  car            Car             @relation(fields: [carId], references: [car_id])
  timeId         String          @db.VarChar(36)
  time           Time            @relation(fields: [timeId], references: [time_id])
  day            DateTime        @default(now())
  remark         String
  code           String?
  bookingStatus  String          @default("await")
  zoneId         String?         @db.VarChar(36)
  zone           Zone?           @relation(fields: [zoneId], references: [zone_id])
  branchId       String          @db.VarChar(36)
  branch         Branch          @relation(fields: [branchId], references: [branch_id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  Fix            Fix[]
  bookingDetails BookingDetail[]
}

model BookingDetail {
  booking_detail_id String   @id @default(uuid()) @db.VarChar(36)
  bookingId         String   @db.VarChar(36)
  booking           Booking  @relation(fields: [bookingId], references: [booking_id])
  serviceId         String   @db.VarChar(36)
  service           Service  @relation(fields: [serviceId], references: [service_id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Fix {
  fix_id       String   @id @default(uuid()) @db.VarChar(36)
  bookingId    String   @db.VarChar(36)
  booking      Booking  @relation(fields: [bookingId], references: [booking_id])
  detailFix    String?
  kmLast       Int?
  kmNext       Int?
  part_total     Int?
  part_point     Float?
  labour_total   Int?
  labour_point   Float?
  totalPrice     Int?
  fixStatus    String   @default("padding")
  card_number    String  
  card           Card     @relation(fields: [card_number], references: [card_number])
  invoice_number String   @unique 
  invoice_date   DateTime? @db.DateTime
  exchange_rate  Int?
  payment_type   String? 
  createBy     String?  @db.VarChar(36)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
