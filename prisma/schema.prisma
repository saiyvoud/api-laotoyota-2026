generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  user_id         String        @id @default(uuid()) @db.VarChar(36)
  customer_number String        @unique @db.VarChar(10)
  username        String
  email           String?
  phoneNumber     String
  password        String
  role            String
  profile         String?
  point           Int           @default(0)
  province        String?
  district        String?
  village         String?
  deviceToken     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  address         String?
  coperate        String?
  corperate_name  String?
  dob             DateTime?
  first_name      String?
  gender          String?
  house           String?
  last_name       String?
  nationality     String?
  ocupation       String?
  pobox           String?
  street          String?
  unit            String?
  booking         Booking[]
  Car             Car[]
  Card            Card[]
  Employee        Employee[]
  GiftHistory     GiftHistory[]
}

model Employee {
  employee_id   String   @id @default(uuid()) @db.VarChar(36)
  employee_code String
  employee_name String
  position      String
  branchId      String   @db.VarChar(36)
  userId        String   @db.VarChar(36)
  createBy      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  branch        Branch   @relation(fields: [branchId], references: [branch_id])
  user          User     @relation(fields: [userId], references: [user_id])

}

model Branch {
  branch_id   String     @id @default(uuid()) @db.VarChar(36)
  branch_code String
  branch_name String
  location    String
  phone       String?
  createBy    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bookings    Booking[]
  Employee    Employee[]
  fix         Fix[]
  timeFixes   TimeFix[]
}

model Promotion {
  promotion_id String   @id @default(uuid()) @db.VarChar(36)
  title        String
  detail       String   @db.Text
  image        String
  createBy     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Service {
  service_id     String          @id @default(uuid()) @db.VarChar(36)
  serviceName    String
  description    String
  image          String
  createBy       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bookingDetails BookingDetail[]
}

model GiftCard {
  giftcard_id String        @id @default(uuid()) @db.VarChar(36)
  amount      Int
  image       String
  status      Boolean       @default(true)
  createBy    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  gift_Code   String        @unique
  gift_Name   String?
  gift_Point  Float?
  GiftHistory GiftHistory[]
}

model GiftHistory {
  gifthistory_id String   @id @default(uuid()) @db.VarChar(36)
  userId         String   @db.VarChar(36)
  giftcardId     String   @db.VarChar(36)
  amount         Int
  status         Boolean  @default(true)
  createBy       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  total          Int?
  cardId         String   @db.VarChar(36)
  card_number    String
  claimed_date   DateTime @db.DateTime(0)
  received    Boolean  @default(false)
  gift_Code      String
  card           Card     @relation(fields: [cardId], references: [card_id])
  giftcard       GiftCard @relation(fields: [giftcardId], references: [giftcard_id])
  user           User     @relation(fields: [userId], references: [user_id])

}

model Card {
  card_id         String        @id @default(uuid()) @db.VarChar(36)
  userId          String?       @db.VarChar(36)
  card_number     String        @unique
  vip_number      String?
  createBy        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  active_point    Int?
  carId           String        @unique @db.VarChar(36)
  card_type       String?
  countCard       Int?
  expiration_date DateTime?
  goldIssued      DateTime      @default(now())
  issued_date     DateTime      @default(now())
  received        String?
  running_labour  Float?
  running_part    Float?
  status          Boolean       @default(false)
  total_point     Int?
  car             Car           @relation(fields: [carId], references: [car_id])
  user            User?         @relation(fields: [userId], references: [user_id])
  Fix             Fix[]
  GiftHistory     GiftHistory[]
}

model Car {
  car_id       String    @id @default(uuid()) @db.VarChar(36)
  userId       String?   @db.VarChar(36)
  model        String
  frameNumber  String
  engineNumber String?
  plateNumber  String
  province     String?
  color        String?
  createBy     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  booking      Booking[]
  user         User?     @relation(fields: [userId], references: [user_id])
  card         Card?


}

model Setting {
  setting_id String   @id @default(uuid()) @db.VarChar(36)
  priceFix   Int
  pricePart  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TimeFix {
  timefix_id String    @id @default(uuid()) @db.VarChar(36)
  timeId     String    @db.VarChar(36)
  branchId   String?   @db.VarChar(36)
  zoneId     String    @db.VarChar(36)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  date       DateTime? @db.DateTime(0)
  branch     Branch?   @relation(fields: [branchId], references: [branch_id])
  time       Time      @relation(fields: [timeId], references: [time_id])
  zone       Zone      @relation(fields: [zoneId], references: [zone_id])


}

model Time {
  time_id    String    @id @default(uuid()) @db.VarChar(36)
  time       String
  date       String?
  timeStatus Boolean   @default(true)
  qty        Int       @default(0)
  createBy   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  bookings   Booking[]
  timeFixes  TimeFix[]
}

model Zone {
  zone_id    String    @id @default(uuid()) @db.VarChar(36)
  zoneName   String
  timeFix    String?
  zoneStatus Boolean
  createBy   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  bookings   Booking[]
  timeFixes  TimeFix[]
}

model Booking {
  booking_id     String          @id @default(uuid()) @db.VarChar(36)
  userId         String          @db.VarChar(36)
  carId          String          @db.VarChar(36)
  timeId         String          @db.VarChar(36)
  day            DateTime        @default(now())
  remark         String
  code           String?
  bookingStatus  String          @default("await")
  branchId       String          @db.VarChar(36)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  zoneId         String?         @db.VarChar(36)
  branch         Branch          @relation(fields: [branchId], references: [branch_id])
  car            Car             @relation(fields: [carId], references: [car_id])
  time           Time            @relation(fields: [timeId], references: [time_id])
  user           User            @relation(fields: [userId], references: [user_id])
  zone           Zone?           @relation(fields: [zoneId], references: [zone_id])
  bookingDetails BookingDetail[]
  Fix            Fix[]

}

model BookingDetail {
  booking_detail_id String   @id @default(uuid()) @db.VarChar(36)
  bookingId         String   @db.VarChar(36)
  serviceId         String   @db.VarChar(36)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  booking           Booking  @relation(fields: [bookingId], references: [booking_id])
  service           Service  @relation(fields: [serviceId], references: [service_id])


}

model Fix {
  fix_id           String    @id @default(uuid()) @db.VarChar(36)
  bookingId        String?   @db.VarChar(36)
  detailFix        String?
  kmLast           Int?
  kmNext           Int?
  totalPrice       Int?
  fixStatus        String?   @default("padding")
  createBy         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  branchId         String?   @db.VarChar(36)
  cardId           String?
  exchange_rate    Int?
  invoice_date     DateTime?
  invoice_number   String    @unique
  labour_point     Int?
  labour_total     Int?
  part_point       Int?
  part_total       Int?
  payment_type     String?
  tax_invoice_code String?
  booking          Booking?  @relation(fields: [bookingId], references: [booking_id])
  branch           Branch?   @relation(fields: [branchId], references: [branch_id])
  card             Card?     @relation(fields: [cardId], references: [card_id])


}
